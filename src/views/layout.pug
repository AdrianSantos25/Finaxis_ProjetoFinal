                  | Início
              li.nav-item
                a.nav-link(href="/dashboard" class=(titulo === 'Dashboard' ? 'active' : ''))
                  i.bi.bi-speedometer2.me-1
                  | Dashboard
              li.nav-item
                a.nav-link(href="/transacoes" class=(titulo === 'Transações' ? 'active' : ''))
                  i.bi.bi-list-ul.me-1
                  | Transações
              li.nav-item
                a.nav-link(href="/categorias" class=(titulo === 'Categorias' ? 'active' : ''))
                  i.bi.bi-tags.me-1
                  | Categorias
              li.nav-item
                a.nav-link(href="/orcamentos" class=(titulo === 'Orçamentos' ? 'active' : ''))
                  i.bi.bi-bullseye.me-1
                  | Orçamentos
              li.nav-item
                a.nav-link(href="/metas" class=(titulo === 'Metas' ? 'active' : ''))
                  i.bi.bi-flag.me-1
                  | Metas
              li.nav-item
                a.nav-link(href="/relatorios" class=(titulo === 'Relatórios' ? 'active' : ''))
                  i.bi.bi-graph-up.me-1
                  | Relatórios
              li.nav-item
                a.nav-link(href="/conta/configuracoes" class=(titulo === 'Configurações da Conta' ? 'active' : ''))
                  i.bi.bi-gear.me-1
                  | Conta
              li.nav-item.dropdown
                a.nav-link.dropdown-toggle.user-menu-toggle(href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false")
                  i.bi.bi-person-circle.me-1
                  span.user-menu-name #{utilizador.nome}
                ul.dropdown-menu.dropdown-menu-end.user-menu-dropdown
                  - const planoTexto = ((planoAtual || 'free') + '').toUpperCase()
                  - const statusBruto = (subscricaoStatus || 'active') + ''
                  - const statusTexto = ({ active: 'Ativo', trialing: 'Em trial', past_due: 'Pendente', canceled: 'Cancelado' })[statusBruto] || statusBruto
                  - const statusClasse = ({ active: 'is-active', trialing: 'is-trial', past_due: 'is-warning', canceled: 'is-canceled' })[statusBruto] || 'is-active'
                  li.user-menu-plan
                    .user-menu-plan-label O seu plano atual
                    .user-menu-plan-row
                      span.user-menu-plan-pill= planoTexto
                      span.user-menu-plan-status(class=statusClasse)= statusTexto
                  li
                    hr.dropdown-divider
                  li
                    a.dropdown-item.user-menu-item(href="/billing")
                      i.bi.bi-credit-card-2-front.me-2
                      | Plano e Faturação
                  li
                    a.dropdown-item.user-menu-item(href="/conta/configuracoes")
                      i.bi.bi-sliders.me-2
                      | Conta e Permissões
                  li
                    hr.dropdown-divider
                  li
                    a.dropdown-item.user-menu-item.text-danger(href="#" data-bs-toggle="modal" data-bs-target="#modalEliminarConta")
                      i.bi.bi-trash.me-2
                      | Eliminar Conta
