{
  "name": "gestor-financeiro",
  "version": "1.0.0",
  "description": "Sistema de gestão financeira pessoal",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "backup:db": "powershell -ExecutionPolicy Bypass -File scripts/backup-db.ps1",
    "check": "node scripts/check-syntax.js",
    "test": "jest --runInBand",
    "generate:secret": "node scripts/generate-session-secret.js 48",
    "prod:check": "node scripts/validate-prod-env.js .env"
  },
  "keywords": [
    "financeiro",
    "gestao",
    "nodejs",
    "express",
    "pug"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "multer": "^2.0.2",
    "mysql2": "^3.16.0",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "pug": "^3.0.3",
    "stripe": "^17.7.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
