# FINAXIS - Ambiente de Producao
NODE_ENV=production
PORT=3001
APP_BASE_URL=https://app.seudominio.com

# Base de Dados
DB_HOST=127.0.0.1
DB_USER=finaxis_user
DB_PASSWORD=trocar_esta_password
DB_NAME=gestor_financeiro
DB_PORT=3306

# Sessao (gere com: npm run generate:secret)
SESSION_SECRET=cole_aqui_o_secret_gerado

# SMTP
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=suporte@seudominio.com
SMTP_PASS=token_ou_password_de_app

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_PRO=price_xxxxx
STRIPE_PRICE_BUSINESS=price_xxxxx

# Backup (opcional, apenas se mysqldump nao estiver no PATH)
# MYSQLDUMP_PATH=C:\\Program Files\\MySQL\\MySQL Server 8.0\\bin\\mysqldump.exe
